{
  "name": "@asom/sdk",
  "version": "0.0.2",
  "description": "TypeScript SDK for asom — create, resolve, and operate agents on Somnia",
  "license": "MIT",
  "author": "Wono Labs",
  "homepage": "https://github.com/TheSupermanish/asom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSupermanish/asom.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/TheSupermanish/asom/issues"
  },
  "keywords": ["somnia", "erc-6551", "agents", "web3", "viem", "asom"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
