{
  "name": "@asom/cli",
  "version": "0.0.2",
  "description": "asom command-line tool — create and operate agents on Somnia",
  "license": "MIT",
  "author": "Wono Labs",
  "homepage": "https://github.com/TheSupermanish/asom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSupermanish/asom.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/TheSupermanish/asom/issues"
  },
  "keywords": ["somnia", "erc-6551", "agents", "cli", "asom"],
  "type": "module",
