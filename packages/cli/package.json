  "dependencies": {
    "@asom/sdk": "workspace:*",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "picocolors": "^1.1.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
